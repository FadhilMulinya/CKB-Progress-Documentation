{
  "manifest_version": 3,
  "name": "CKB Wallet",
  "version": "1.0.0",
  "description": "Simple CKB wallet — send & receive on testnet",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons.png",
      "32": "icons.png",
      "48": "icons.png",
      "128": "icons.png"
    }
  },
  "icons": {
    "16": "icons.png",
    "32": "icons.png",
    "48": "icons.png",
    "128": "icons.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://testnet.ckb.dev/*"
  ]
}
