{
  "manifest_version": 3,
  "name": "CKB Wallet",
  "description": "Nervos CKB Testnet Wallet Extension",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icons.png",
    "32": "icons/icons.png",
    "48": "icons/icons.png",
    "128": "icons/icons.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://*.ckbccc.com/*",
    "https://*.nervos.org/*",
    "https://*.ckbapp.dev/*",
    "https://*.ckb.dev/*"
  ],
  "permissions": [
    "storage"
  ]
}